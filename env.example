# Backend (copy to backend/.env or export in shell)
OPENAI_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=hr-policies
# Optional: Pinecone serverless / custom host URL from the Pinecone console
PINECONE_HOST=

GOOGLE_DRIVE_ROOT_FOLDER_ID=

# Path to Google service account JSON (Drive read scope)
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Optional tuning
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini
CHUNK_SIZE=1800
CHUNK_OVERLAP=250
RETRIEVAL_TOP_K=8
MIN_RETRIEVAL_SCORE=0.32
NAMESPACE=hr

# Comma-separated origins for the React dev server
CORS_ORIGINS=http://localhost:5173
